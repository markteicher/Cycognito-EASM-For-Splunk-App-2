          <query>| tstats `summariesonly` values(Assets.countries) as countries latest(Assets.organizations) as organizations latest(Assets.security_grade) as Grade latest(Assets.status) as Status latest(Assets.security_score) as Score from datamodel=CyCognito_Assets where Assets.countries $location$ AND Assets.organizations $organization$ AND Assets.countries!="-" AND Assets.security_grade $grade_2$ by Assets.id, _time
| where Status != "Removed" AND Score != "null"
| mvexpand countries
| eventstats latest(_time) as time1 by Assets.id
| where _time=time1
| chart count over countries by Grade 
| rename countries as Location 
| addtotals 
| sort 10 - Total 
| fields - Total</query>
          <earliest>$time_range.earliest$</earliest>
