  <row>
    <panel>
      <title>🛠️ Vulnerability</title>
    </panel>
  </row>
  <row>
    <panel>
      <title>🔥 Most Common Issue Type</title>
      <single>
        <search>
          <query>| tstats `summariesonly` latest(Assets.countries) as countries latest(Assets.organizations) as organizations latest(Assets.status) as Status from datamodel=CyCognito_Assets where Assets.countries $location$ AND Assets.organizations $organization$ by Assets.id 
| where Status != "Removed"
| rename Assets.id as unique_id 
| join type=inner unique_id max=0
    [| tstats `summariesonly` latest(Issues.affected_asset) as unique_id values(Issues.issue_types) as "Issue Type" latest(Issues.issue_status) as Status from datamodel=CyCognito_Issues where Issues.severity="High" OR Issues.severity="Critical" by Issues.id, _time | where Status = "New" OR Status = "Unresolved" | mvexpand "Issue Type"
| eventstats latest(_time) as time1 by Issues.id
| where _time=time1 ] 
| top 1 "Issue Type"</query>
          <earliest>$time_range.earliest$</earliest>
          <latest>$time_range.latest$</latest>
        </search>
        <option name="drilldown">all</option>
        <option name="refresh.display">progressbar</option>
        <drilldown>
          <link target="_blank">search?q=%60get_cycognito_index%60%20source%3D%22cycognito_assets%22%20sourcetype!%3D%22cycognito%3Aassets%3Aiprange%22%0A%7C%20dedup%20id%20%0A%7C%20rename%20id%20as%20unique_id%20%0A%7C%20where%20status!%3D%22Removed%22%0A%7C%20join%20type%3Dinner%20unique_id%20max%3D0%0A%20%20%20%20%5B%7C%20search%20%60get_cycognito_index%60%20source%3Dcycognito_issues%20%0A%20%20%20%20%7C%20search%20severity%3D%22High%22%20OR%20severity%3D%22Critical%22%20%0A%20%20%20%20%7C%20dedup%20id%0A%20%20%20%20%7C%20rename%20affected_asset%20as%20unique_id%20%0A%20%20%20%20%7C%20where%20issue_status%20%3D%20%22New%22%20OR%20issue_status%20%3D%20%22Unresolved%22%0A%20%20%20%20%20%20%20%20%5D%20%0A%7C%20where%20issue_types%3D%22$click.value$%22&amp;earliest=$time_range.earliest$&amp;latest=$time_range.latest$</link>
        </drilldown>
      </single>
