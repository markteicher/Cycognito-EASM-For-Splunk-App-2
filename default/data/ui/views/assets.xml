          <query>| tstats `summariesonly` latest(Assets.security_grade) as Grade latest(Assets.security_score) as Score values(Assets.tags) as Tag latest(Assets.countries) as countries latest(Assets.organizations) as organizations latest(Assets.status) as Status from datamodel=CyCognito_Assets where Assets.countries $location$ AND Assets.organizations $organization$ AND Assets.tags!=NULL AND Assets.security_grade $grade_3$ by Assets.id, _time
| where Status != "Removed" AND Score != "null"
| mvexpand Tag 
| eventstats latest(_time) as time1 by Assets.id
| where _time=time1 
| chart count over Tag by Grade
| addtotals
| where Tag!="" 
| sort 10 - Total 
| fields - Total</query>
          <earliest>$time_range.earliest$</earliest>
