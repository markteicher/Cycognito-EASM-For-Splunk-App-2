<!--
=============================================================================
 default/data/ui/views/assets.xml
 CyCognito for Splunk App
 Assets Dashboard
=============================================================================

PURPOSE

Operational dashboard for visualizing CyCognito asset posture, exposure, and
risk trends across grade, status, type, tag, location, and issue context.

This dashboard provides:

- time-bounded asset posture review
- location- and organization-scoped asset analysis
- asset grade distribution
- asset status distribution
- asset type distribution
- grade trend analysis over time
- status trend analysis over time
- asset tag distribution
- high-risk issue type summary
- risky location prioritization
- top asset investigation table

DATA SOURCE

This dashboard is powered by CyCognito data models in Splunk:

- datamodel=CyCognito_Assets
- datamodel=CyCognito_Issues

Supporting drilldowns query CyCognito indexed events through:

- `get_cycognito_index`
- source=cycognito_assets
- source=cycognito_issues

PRIMARY ANALYSIS OBJECTIVE

Provide an operational view for analysts to identify:

- assets with poor security grades
- asset posture changes over time
- concentrations of risky asset types and tags
- locations with elevated asset risk
- unresolved high and critical issue concentration
- top assets requiring review in the CyCognito portal

FILTER MODEL

Dashboard filtering is controlled by:

- Time Range
- Location
- Organization

Panel-scoped filtering is additionally controlled by:

- Grade
- Status
- Type

RISK MODEL

This dashboard prioritizes assets using CyCognito posture and issue context.

Primary asset prioritization signals:
- security_grade
- security_score
- status
- severe_issues
- tags
- countries
- organizations

Issue prioritization is focused on:
- severity = High
- severity = Critical
- issue_status = New
- issue_status = Unresolved

=============================================================================
-->
<form theme="dark" version="1.1" script="multiselect_input.js">
  <label>🖥️ Assets</label>
  <fieldset submitButton="false">
    <input type="time" token="time_range">
      <label>⏱️ Time Range</label>
      <default>
        <earliest>-24h@h</earliest>
        <latest>now</latest>
      </default>
    </input>
    <input type="multiselect" token="location" searchWhenChanged="true">
      <label>🌍 Location</label>
      <choice value="*">All</choice>
      <default>*</default>
      <fieldForLabel>Location</fieldForLabel>
      <fieldForValue>Location</fieldForValue>
      <search>
        <query>| tstats `summariesonly` values(Assets.countries) AS Location from datamodel=CyCognito_Assets where Assets.countries!="-"  
| mvexpand Location 
| table Location</query>
        <earliest>$time_range.earliest$</earliest>
        <latest>$time_range.latest$</latest>
      </search>
      <initialValue>*</initialValue>
      <prefix>IN (</prefix>
      <suffix>)</suffix>
      <valuePrefix>"</valuePrefix>
      <delimiter>, </delimiter>
      <valueSuffix>"</valueSuffix>
    </input>
    <input type="multiselect" token="organization" searchWhenChanged="true">
      <label>🏢 Organization</label>
      <choice value="*">All</choice>
      <default>*</default>
      <fieldForLabel>Organization</fieldForLabel>
      <fieldForValue>Organization</fieldForValue>
      <search>
        <query>| tstats `summariesonly` values(Assets.organizations) AS Organization from datamodel=CyCognito_Assets where Assets.organizations!="-"  
| mvexpand Organization  
| table Organization</query>
        <earliest>$time_range.earliest$</earliest>
        <latest>$time_range.latest$</latest>
      </search>
      <initialValue>*</initialValue>
      <prefix>IN (</prefix>
      <suffix>)</suffix>
      <valuePrefix>"</valuePrefix>
      <valueSuffix>"</valueSuffix>
      <delimiter>, </delimiter>
    </input>
  </fieldset>
  <row>
    <panel>
      <title>📊 Assets Overview</title>
    </panel>
  </row>
  <row>
    <panel>
      <title>🛡️ Assets by Grade</title>
      <chart>
        <search>
          <query>| tstats `summariesonly` latest(Assets.security_grade) as Grade latest(Assets.countries) as countries latest(Assets.security_score) as Score latest(Assets.organizations) as organizations latest(Assets.status) as Status from datamodel=CyCognito_Assets where Assets.countries $location$ AND Assets.organizations $organization$  by Assets.id 
| where Status != "Removed" AND Score != "null"
| stats count as Count by Grade</query>
          <earliest>$time_range.earliest$</earliest>
          <latest>$time_range.latest$</latest>
        </search>
        <option name="charting.chart">pie</option>
        <option name="charting.drilldown">all</option>
        <option name="charting.fieldColors">{"A":0x2D3763,"B":0x7E9CDB,"C":0xA872D4, "D":0xFCA94A, "F":0xCF453B, "N/A":0x7875F4}</option>
        <option name="refresh.display">progressbar</option>
        <drilldown>
          <link target="_blank">search?q=%60get_cycognito_index%60%20source%3Dcycognito_assets%20sourcetype!%3D%22cycognito%3Aassets%3Aiprange%22%20%0A%7C%20dedup%20id%20%0A%7C%20search%20countries%20$location$%20AND%20organizations%20$organization$%20AND%20security_grade%3D%22$click.value$%22%20AND%20status!%3D%22Removed%22%20AND%20security_score!%3D%22null%22&amp;earliest=$time_range.earliest$&amp;latest=$time_range.latest$</link>
        </drilldown>
      </chart>
    </panel>
    <panel>
      <title>🔄 Assets by Status</title>
      <chart>
        <search>
          <query>| tstats `summariesonly` latest(Assets.status) as Status latest(Assets.countries) as countries latest(Assets.organizations) as organizations from datamodel=CyCognito_Assets where Assets.countries $location$ AND Assets.organizations $organization$ by Assets.id 
| stats count as Count by Status</query>
          <earliest>$time_range.earliest$</earliest>
          <latest>$time_range.latest$</latest>
        </search>7D3FD3<option name="charting.chart">pie</option>
        <option name="charting.drilldown">all</option>
        <option name="charting.fieldColors">{"Normal":7D3FD3,"Changed":2D3763,"New":3865C1, "Removed":6583C2}</option>
        <option name="refresh.display">progressbar</option>
        <drilldown>
          <link target="_blank">search?q=%60get_cycognito_index%60%20source%3Dcycognito_assets%20sourcetype!%3D%22cycognito%3Aassets%3Aiprange%22%20%0A%7C%20dedup%20id%20%0A%7C%20search%20countries%20$location$%20AND%20organizations%20$organization$%20AND%20status%3D%22$click.value$%22&amp;earliest=$time_range.earliest$&amp;latest=$time_range.latest$</link>
        </drilldown>
      </chart>
    </panel>
    <panel>
      <title>🧩 Assets by Type</title>
      <chart>
        <search>
          <query>| tstats `summariesonly` latest(Assets.type) as Type latest(Assets.status) as Status latest(Assets.countries) as countries latest(Assets.organizations) as organizations from datamodel=CyCognito_Assets where Assets.countries $location$ AND Assets.organizations $organization$ by Assets.id 
| where Status != "Removed"
| stats count as Count by Type</query>
          <earliest>$time_range.earliest$</earliest>
          <latest>$time_range.latest$</latest>
        </search>
        <option name="charting.chart">pie</option>
        <option name="charting.drilldown">all</option>
        <option name="charting.fieldColors">{"Domain":FCA94A,"Ip":2D3763,"Webapp":A872D4,"Cert":6583C2}</option>
        <option name="refresh.display">progressbar</option>
        <drilldown>
          <link target="_blank">search?q=%60get_cycognito_index%60%20source%3Dcycognito_assets%20sourcetype!%3D%22cycognito%3Aassets%3Aiprange%22%20%0A%7C%20dedup%20id%20%0A%7C%20search%20countries%20$location$%20AND%20organizations%20$organization$%20AND%20type%3D%22$click.value$%22%20AND%20status!%3D%22Removed%22&amp;earliest=$time_range.earliest$&amp;latest=$time_range.latest$</link>
        </drilldown>
      </chart>
    </panel>
  </row>
  <row>
    <panel>
      <title>📈 Assets by Grade over Time</title>
      <input type="multiselect" token="grade_1" searchWhenChanged="true">
        <label>🏷️ Grade</label>
        <choice value="*">All</choice>
        <default>D,F</default>
