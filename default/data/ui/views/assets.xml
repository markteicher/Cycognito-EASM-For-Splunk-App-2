          <latest>$time_range.latest$</latest>
        </search>
        <prefix>IN (</prefix>
        <suffix>)</suffix>
        <initialValue>D,F</initialValue>
        <valuePrefix>"</valuePrefix>
        <valueSuffix>"</valueSuffix>
        <delimiter>, </delimiter>
      </input>
      <chart>
        <search>
          <query>| tstats `summariesonly` latest(Assets.security_grade) as security_grade latest(_time) as _time latest(Assets.countries) as countries latest(Assets.organizations) as organizations latest(Assets.security_score) as Score latest(Assets.status) as Status from datamodel=CyCognito_Assets where Assets.countries $location$ AND Assets.organizations $organization$ AND Assets.security_grade $grade_1$ by Assets.id 
| where Status != "Removed" AND Score != "null"
| timechart span=1mon count by security_grade 
| addtotals</query>
          <earliest>$time_range.earliest$</earliest>
          <latest>$time_range.latest$</latest>
        </search>
        <option name="charting.axisTitleX.text">Time</option>
        <option name="charting.axisTitleY.text">Assets</option>
        <option name="charting.axisY.abbreviation">auto</option>
        <option name="charting.chart">line</option>
        <option name="charting.chart.nullValueMode">connect</option>
        <option name="charting.chart.showDataLabels">all</option>
        <option name="charting.drilldown">all</option>
        <option name="charting.fieldColors">{"A":0x2D3763,"B":0x7E9CDB,"C":0xA872D4, "D":0xFCA94A, "F":0xCF453B, "N/A":0x7875F4,"Total":CF453B}</option>
        <option name="charting.legend.placement">bottom</option>
        <option name="refresh.display">progressbar</option>
        <drilldown>
          <condition match="$click.name2$=&quot;Total&quot; AND isnull($click.value$)">
            <link target="_blank">search?q=%60get_cycognito_index%60%20source%3D%22cycognito_assets%22%20sourcetype!%3D%22cycognito%3Aassets%3Aiprange%22%0A%7C%20dedup%20id%20%0A%7C%20search%20countries%20$location$%20AND%20organizations%20$organization$%20AND%20security_grade%20$grade_1$%20AND%20status!%3D%22Removed%22%20AND%20security_score!%3D%22null%22&amp;earliest=$time_range.earliest$&amp;latest=$time_range.latest$</link>
          </condition>
          <condition match="$click.name2$=&quot;Total&quot; AND isnotnull($click.value$)">
            <link target="_blank">search?q=%60get_cycognito_index%60%20source%3D%22cycognito_assets%22%20sourcetype!%3D%22cycognito%3Aassets%3Aiprange%22%20earliest%3D%22$time_range.earliest$%22%20latest%3D%22$time_range.latest$%22%20%0A%7C%20dedup%20id%20%0A%7C%20search%20countries%20$location$%20AND%20organizations%20$organization$%20AND%20security_grade%20$grade_1$%20AND%20_time%3E%3D%22$earliest$%22%20AND%20_time%3C%3D%22$latest$%22%20AND%20status!%3D%22Removed%22%20AND%20security_score!%3D%22null%22&amp;earliest=$time_range.earliest$&amp;latest=$time_range.latest$</link>
          </condition>
          <condition match="isnull($click.value$)">
            <link target="_blank">search?q=%60get_cycognito_index%60%20source%3D%22cycognito_assets%22%20sourcetype!%3D%22cycognito%3Aassets%3Aiprange%22%0A%7C%20dedup%20id%20%0A%7C%20search%20countries%20$location$%20AND%20organizations%20$organization$%20AND%20security_grade%3D%22$click.name2$%22%20AND%20status!%3D%22Removed%22%20AND%20security_score!%3D%22null%22&amp;earliest=$time_range.earliest$&amp;latest=$time_range.latest$</link>
          </condition>
          <condition>
            <link target="_blank">search?q=%60get_cycognito_index%60%20source%3D%22cycognito_assets%22%20sourcetype!%3D%22cycognito%3Aassets%3Aiprange%22%20earliest%3D%22$time_range.earliest$%22%20latest%3D%22$time_range.latest$%22%20%0A%7C%20dedup%20id%20%0A%7C%20search%20countries%20$location$%20AND%20organizations%20$organization$%20AND%20security_grade%3D%22$click.name2$%22%20AND%20_time%3E%3D%22$earliest$%22%20AND%20_time%3C%3D%22$latest$%22%20AND%20status!%3D%22Removed%22%20AND%20security_score!%3D%22null%22&amp;earliest=$time_range.earliest$&amp;latest=$time_range.latest$</link>
          </condition>
        </drilldown>
      </chart>
    </panel>
    <panel>
      <title>📈 Assets by Status over Time</title>
      <input type="multiselect" token="status_1" searchWhenChanged="true">
