          <a class="portal-link" href="https://www.cycognito.com/documents/datasheets/CyCognito-DS-Prioritization-and-Remediation-Mar2024.pdf" target="_blank">
            <div class="portal-tile">
              <div class="portal-icon">📈</div>
              <div class="portal-title">Prioritization and Remediation</div>
            </div>
          </a>

          <a class="portal-link" href="https://www.cycognito.com/documents/datasheets/DS-Exploit-Intelligence-v6.pdf" target="_blank">
            <div class="portal-tile">
              <div class="portal-icon">🎯</div>
              <div class="portal-title">Exploit Intelligence</div>
